{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the inbox, composer, dock, and settings windows",
  "windows": ["inbox", "composer", "dock", "settings", "recording"],
  "permissions": [
    "core:default",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-start-dragging",
    "updater:default",
    "process:default",
    "store:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "kokobrain:*"
        }
      ]
    }
  ]
}
