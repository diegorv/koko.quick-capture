{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "quick-capture",
  "version": "1.0.1",
  "identifier": "com.koko.quick-capture",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bash scripts/tauri-before-build.sh",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "inbox",
        "title": "quick-capture",
        "url": "/inbox",
        "width": 900,
        "height": 600,
        "visible": false,
        "focus": true,
        "center": true,
        "decorations": true,
        "alwaysOnTop": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/diegorv/koko.quick-capture/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM4ODU0NTVDNzlBNjRDMjEKUldRaFRLWjVYRVdGeUdVY242SGxXak5ReXNILy9nUFJudEJtNjhtUnJIZGdoME10Yk9POWlrQXkK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "11.0"
    }
  }
}
